{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:public": "VITE_PUBLIC_MODE=true vite --config vite.config.public.ts",
    "build": "tsc && vite build",
    "build:public": "VITE_PUBLIC_MODE=true tsc && VITE_PUBLIC_MODE=true vite build --config vite.config.public.ts && npm run build:api",
    "build:api": "esbuild serverless/markets.ts --bundle --platform=node --format=cjs --target=node18 --packages=external --outfile=api/markets.js && esbuild serverless/orderbook.ts --bundle --platform=node --format=cjs --target=node18 --packages=external --outfile=api/trade/orderbook.js",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.12",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
