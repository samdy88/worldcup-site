{
 "name": "bot",
 "version": "0.1.0",
 "private": true,
 "scripts": {
 "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
 "build": "tsc",
 "test": "vitest run",
 "test:watch": "vitest",
 "lint": "eslint src --ext .ts",
 "typecheck": "tsc --noEmit",
 "sync-teams": "ts-node --project tsconfig.scripts.json --transpile-only scripts/syncTeamNames.ts",
 "dryrun-canonicalize": "ts-node --project tsconfig.scripts.json --transpile-only scripts/dryrunCanonicalize.ts"
 },
 "dependencies": {
 "@polymarket/clob-client-v2": "^1.0.2",
 "@prisma/client": "^5.22.0",
 "@types/cors": "^2.8.19",
 "centrifuge": "^5.2.1",
 "compression": "^1.8.1",
 "cors": "^2.8.6",
 "dotenv": "^16.4.7",
 "ethers": "^6.13.5",
 "express": "^4.21.2",
 "grammy": "^1.34.0",
 "pino": "^10.3.1",
 "pino-pretty": "^13.1.3",
 "viem": "^2.48.4",
 "ws": "^8.18.0",
 "zod": "^3.24.2"
 },
 "devDependencies": {
 "@types/compression": "^1.8.1",
 "@types/express": "^4.17.21",
 "@types/node": "^22.10.7",
 "@types/supertest": "^6.0.2",
 "@types/ws": "^8.5.13",
 "prisma": "^5.22.0",
 "supertest": "^7.0.0",
 "ts-node-dev": "^2.0.0",
 "typescript": "^5.7.3",
 "vitest": "^2.1.8"
 }
}
